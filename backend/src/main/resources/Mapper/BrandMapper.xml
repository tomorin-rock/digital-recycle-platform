<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.mapper.BrandMapper">
    <insert id="insert" parameterType="com.demo.entity.ProductBrand" useGeneratedKeys="true" keyProperty="id">
        insert into productbrand(name, logo,sort,status)
        values (#{name}, #{logo},#{sort},#{status})
    </insert>
    <update id="update" parameterType="com.demo.entity.ProductBrand">
        update productbrand
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="logo != null and logo != ''">logo = #{logo},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>
    <delete id="delete">
        delete
        from productbrand
        where id = #{id}
    </delete>
    <select id="selectById" resultType="com.demo.entity.ProductBrand">
        select *
        from productbrand
        where id = #{id}
    </select>
    <select id="selectAll" resultType="com.demo.entity.ProductBrand">
        select *
        from productbrand
    </select>
    <select id="brandList" resultType="com.demo.entity.ProductBrand">
        select *
        from productbrand
        where status = 1
        order by sort
    </select>
</mapper>